<?xml version="1.0"?>
<ruleset name="Lime Stock Watchlist">
	<description>PHPCS rules for the Lime Stock Watchlist plugin.</description>

	<file>.</file>
	<exclude-pattern>vendor/</exclude-pattern>
	<exclude-pattern>node_modules/</exclude-pattern>
	<exclude-pattern>build/</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<config name="minimum_wp_version" value="6.5"/>

	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array" value="lime-stock-watchlist"/>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array"
				value="lime_stock_watchlist,Lime_Stock_Watchlist,LSWL,lswl"/>
		</properties>
	</rule>
</ruleset>
